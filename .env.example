# --- LLM (Claude) ---
# Claude Code Max subscription: run `claude setup-token` and paste the token
# (sk-ant-oat01-...) here. No Anthropic API key needed.
CLAUDE_CODE_OAUTH_TOKEN=
# Optional fallback if you have a pay-per-use API key instead:
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- NVIDIA OCR (build.nvidia.com) ---
NVIDIA_API_KEY=
NVIDIA_OCR_MODEL=baidu/paddleocr

# --- Google (Drive + Sheets) ---
# OAuth client from Google Cloud Console (type: Web application).
# Add the redirect URI below to the client's authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/google/callback
# Optional: existing ids; auto-created if blank
GOOGLE_SPREADSHEET_ID=
GOOGLE_DRIVE_FOLDER_ID=

# --- Server ---
PORT=8000
WEB_ORIGIN=http://localhost:5173
