# --- LLM (Claude) ---
# Claude Code Max subscription: run `claude setup-token` and paste the token
# (sk-ant-oat01-...) here. No Anthropic API key needed.
CLAUDE_CODE_OAUTH_TOKEN=
# Optional fallback if you have a pay-per-use API key instead:
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- NVIDIA OCR (build.nvidia.com) ---
NVIDIA_API_KEY=
NVIDIA_OCR_MODEL=baidu/paddleocr

# --- OpenAI OCR (optional, platform.openai.com) ---
OPENAI_API_KEY=

# --- Google (Drive + Sheets) ---
# All optional: OAuth client credentials can instead be pasted in the app
# (Settings → Google sync). Values here act as a fallback.
# OAuth client from Google Cloud Console (type: Web application).
# Add the redirect URI below to the client's authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/google/callback

# --- Server ---
PORT=8000
WEB_ORIGIN=http://localhost:5173

# --- Security ---
# Set a random secret to require X-Api-Key on all endpoints. Leave empty for
# open access (safe for localhost-only dev). Generate with: openssl rand -hex 32
API_KEY=
